{
  "expo": {
    "name": "FichaX",
    "slug": "fichax",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#007AFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.leona.fichax"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#007AFF"
      },
      "package": "com.leona.fichax"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": false,
          "asyncRoutes": false
        }
      ]
    ],
    "scheme": "fichax",
    "extra": {
      "router": {
        "origin": false,
        "asyncRoutes": false
      },
      "eas": {
        "projectId": "70b5f4ef-4884-462d-932c-4c8d7949baac"
      }
    }
  }
}
